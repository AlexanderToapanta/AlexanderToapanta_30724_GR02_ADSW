@startuml
title Arquitectura por Capas - IronClad Box\nMVC + Patrón Builder\nRQ-01 al RQ-04

skinparam packageStyle rectangle
skinparam shadowing false
skinparam defaultFontName Arial
skinparam rectangle {
  RoundCorner 12
}

left to right direction

actor "Administrador" as Admin
actor "Entrenador" as Trainer

package "Capa de Presentación\n(View)" #E3F2FD {
  rectangle "AdminDashboardView\nGestiona clases,\nmembresías y usuarios" as AdminView
  rectangle "TrainerDashboardView\nGestiona progreso\ndeportivo" as TrainerView
}

package "Capa Controladora\n(Controller - MVC)" #FFF3E0 {
  rectangle "ClaseController\nRQ-01" as ClaseController
  rectangle "MembresiaController\nRQ-02" as MembresiaController
  rectangle "UsuarioController\nRQ-03" as UsuarioController
  rectangle "ProgresoController\nRQ-04" as ProgresoController
}

package "Capa de Lógica de Negocio\n(Model / Services)" #E8F5E9 {
  rectangle "ClaseService\nGestiona horarios,\ncupos y entrenadores" as ClaseService
  rectangle "MembresiaService\nControla membresías,\npagos y renovaciones" as MembresiaService
  rectangle "UsuarioService\nAdministra cuentas,\nroles y permisos" as UsuarioService
  rectangle "ProgresoService\nRegistra resultados WOD\ny consulta historial" as ProgresoService

  rectangle "ClaseBuilder\n<<Builder>>\nConstruye objeto Clase:\nfecha, hora, cupo,\nentrenador" as ClaseBuilder #F3E5F5

  rectangle "MembresiaBuilder\n<<Builder>>\nConstruye objeto Membresía:\ntipo, precio, estado,\nvencimiento" as MembresiaBuilder #F3E5F5

  rectangle "UsuarioBuilder\n<<Builder>>\nConstruye objeto Usuario:\nnombre, correo, rol,\nestado" as UsuarioBuilder #F3E5F5

  rectangle "RegistroProgresoBuilder\n<<Builder>>\nConstruye registro:\nWOD, tiempo, peso,\nrepeticiones" as ProgresoBuilder #F3E5F5

  note right of ClaseBuilder
    Builder se aplica para construir objetos
    complejos de forma ordenada antes de
    enviarlos a la capa de datos.

    Relación:
    RQ-01 -> ClaseBuilder
    RQ-02 -> MembresiaBuilder
    RQ-03 -> UsuarioBuilder
    RQ-04 -> RegistroProgresoBuilder
  end note
}

package "Capa de Acceso a Datos\n(DAO / Repository)" #FCE4EC {
  rectangle "ClaseDAO" as ClaseDAO
  rectangle "MembresiaDAO" as MembresiaDAO
  rectangle "UsuarioDAO" as UsuarioDAO
  rectangle "ProgresoDAO" as ProgresoDAO
}

database "Base de Datos\nPostgreSQL / MySQL" #E0E0E0 {
  rectangle "clases" as TClases
  rectangle "membresias" as TMembresias
  rectangle "usuarios" as TUsuarios
  rectangle "progreso_atletas" as TProgreso
}

Admin --> AdminView
Trainer --> TrainerView

AdminView --> ClaseController : RQ-01 gestionar clases
AdminView --> MembresiaController : RQ-02 membresías y pagos
AdminView --> UsuarioController : RQ-03 gestión usuarios
TrainerView --> ProgresoController : RQ-04 seguimiento deportivo

ClaseController --> ClaseService : envía datos de clase
MembresiaController --> MembresiaService : envía datos de membresía
UsuarioController --> UsuarioService : envía datos de usuario
ProgresoController --> ProgresoService : envía resultados WOD

ClaseService --> ClaseBuilder : construye clase
MembresiaService --> MembresiaBuilder : construye membresía
UsuarioService --> UsuarioBuilder : construye usuario
ProgresoService --> ProgresoBuilder : construye registro

ClaseBuilder --> ClaseService : retorna objeto Clase
MembresiaBuilder --> MembresiaService : retorna objeto Membresía
UsuarioBuilder --> UsuarioService : retorna objeto Usuario
ProgresoBuilder --> ProgresoService : retorna objeto RegistroProgreso

ClaseService --> ClaseDAO : guardar / editar / eliminar
MembresiaService --> MembresiaDAO : registrar pago / renovar
UsuarioService --> UsuarioDAO : crear / editar / desactivar
ProgresoService --> ProgresoDAO : guardar / consultar progreso

ClaseDAO --> TClases
MembresiaDAO --> TMembresias
UsuarioDAO --> TUsuarios
ProgresoDAO --> TProgreso

legend right
| Color | Significado |
|<#E3F2FD>| Capa de Presentación |
|<#FFF3E0>| Capa Controladora MVC |
|<#E8F5E9>| Lógica de Negocio |
|<#F3E5F5>| Patrón Builder |
|<#FCE4EC>| Acceso a Datos |
|<#E0E0E0>| Base de Datos |
endlegend

@enduml